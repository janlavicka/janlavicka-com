{
  "name": "janlavicka-com",
  "version": "1.0.0",
  "private": true,
  "description": "Source code of my personal website",
  "license": "MIT",
  "author": "Jan Lavička <iam@janlavicka.com>",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:watch": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lint": "oxlint",
    "format": "oxfmt --check",
    "typecheck": "npm run typegen && tsc --noEmit",
    "typegen": "wrangler types && react-router typegen"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.13.18",
    "@react-router/fs-routes": "^8.0.0",
    "@react-router/node": "^8.0.0",
    "@react-router/serve": "^8.0.0",
    "feed": "^5.2.1",
    "framer-motion": "^12.31.0",
    "gray-matter": "^4.0.3",
    "isbot": "^5.1.31",
    "marked": "^18.0.0",
    "posthog-js": "^1.344.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router": "^8.0.0",
    "remix-utils": "^9.0.0",
    "schema-dts": "^2.0.0",
    "sitemap": "^9.0.0",
    "tailwind-merge": "^3.3.1",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^8.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "lefthook": "^2.0.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.58.0",
    "tailwindcss": "^4.1.16",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.45.3"
  }
}
